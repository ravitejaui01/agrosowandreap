# Copy this file to .env:  cp .env.example .env

PORT=3000

# Use a remote PostgreSQL database (Railway, Neon, Supabase, etc.) — no local Docker needed.
# Get the connection URL from your provider (e.g. Railway → Postgres → Connect → DATABASE_PUBLIC_URL).
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# On Railway: add Postgres to your project, then in the API service add variable:
#   DATABASE_PUBLIC_URL → Reference → Postgres → DATABASE_PUBLIC_URL

# Optional: use local PostgreSQL (Docker) instead:
# DATABASE_URL=postgres://agroforestry:agroforestry@localhost:5432/agroforestry
# Then run: docker-compose up -d

# Supabase — required for GET /api/kml/:id (direct KML download from coconut_plantations)
# Also supports VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY if set in env
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
