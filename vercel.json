{
  "version": 2,
  "name": "agroforestry",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "Agroforestry/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/Agroforestry/index.html"
    }
  ]
}
