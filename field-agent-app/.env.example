# API base URL. Required for data to reach Railway database.
# Set to your Railway API URL so submissions go to Railway (and save to Postgres).
# Example: https://api-production-de18.up.railway.app (no trailing slash)
# Leave empty only when testing with local API (proxy → localhost:3000)
VITE_API_URL=

# Supabase (optional — for @supabase/supabase-js client)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
